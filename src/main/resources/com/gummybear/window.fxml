<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<BorderPane fx:id="windowRoot" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" styleClass="window" stylesheets="@style/window.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.gummybear.WindowController">
   <top>
      <HBox fx:id="windowTitleBarHBox" alignment="CENTER_RIGHT" prefHeight="25.0" styleClass="title-bar" stylesheets="@style/window.css" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="windowTitleLabel" styleClass="window-title-label" stylesheets="@style/window.css" text="Label">
               <padding>
                  <Insets bottom="4.0" left="8.0" right="8.0" top="4.0" />
               </padding>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="windowMinimizeButton" mnemonicParsing="false" onAction="#minimizeWindow" prefHeight="25.0" prefWidth="30.0" styleClass="window-control-button" stylesheets="@style/window.css" text="＿" />
            <Button fx:id="windowMaximizeButton" mnemonicParsing="false" onAction="#maximizeWindow" prefHeight="25.0" prefWidth="30.0" styleClass="window-control-button" stylesheets="@style/window.css" text="☐" />
            <Button fx:id="windowExitButton" mnemonicParsing="false" onAction="#exitWindow" prefHeight="25.0" prefWidth="30.0" stylesheets="@style/window.css" text="╳">
               <styleClass>
                  <String fx:value="window-control-button" />
                  <String fx:value="window-exit-button" />
               </styleClass>
            </Button>
         </children>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
      </HBox>
   </top>
</BorderPane>
